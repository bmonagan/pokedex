{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "esnext",
    "module": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "type": "module",
    "scripts": {
      "build": "npx tsc",
      "start": "node dist/main.js",
      "dev": "npx tsc && node dist/main.js"
    }
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["node_modules"]
}